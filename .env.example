# ── Admin login ────────────────────────────────────────────────────────────
# The single password you'll type at /admin/login
ADMIN_PASSWORD=change-me-to-a-strong-password
# Secret used to sign the login session cookie. Generate one with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=change-me-to-a-long-random-string

# ── Cloudinary (image + video uploads) ─────────────────────────────────────
# From your Cloudinary dashboard → Settings → API Keys
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ── Content store (Upstash Redis / Vercel KV) ──────────────────────────────
# Vercel KV integration sets these automatically. If using Upstash directly,
# the app also accepts UPSTASH_REDIS_REST_URL / UPSTASH_REDIS_REST_TOKEN.
KV_REST_API_URL=
KV_REST_API_TOKEN=
